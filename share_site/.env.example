# Public base URL of the R2 bucket (no trailing slash)
# Format: https://pub-<hash>.r2.dev  OR your custom domain
R2_PUBLIC_URL=https://pub-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.r2.dev

# Public base URL of this share site (no trailing slash)
# Used for Open Graph og:url and social share links
SITE_URL=https://yoursharesite.onrender.com
