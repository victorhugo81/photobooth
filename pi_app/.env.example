# Cloudflare R2 credentials
R2_ACCOUNT_ID=your_account_id_here
R2_ACCESS_KEY_ID=your_access_key_id_here
R2_SECRET_ACCESS_KEY=your_secret_access_key_here
R2_BUCKET_NAME=photobooth-photos

# Public URL for the R2 bucket (enable public access in R2 dashboard)
# Format: https://pub-<hash>.r2.dev  OR your custom domain
R2_PUBLIC_URL=https://pub-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.r2.dev

# URL of the deployed share site (Render free tier)
SHARE_SITE_URL=https://yoursharesite.onrender.com

# Flask settings
FLASK_ENV=production
FLASK_RUN_HOST=0.0.0.0
FLASK_RUN_PORT=5000
